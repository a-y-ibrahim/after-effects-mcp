{
  "name": "after-effects-mcp",
  "version": "1.6.4",
  "description": "MCP server that gives AI assistants full programmatic control of Adobe After Effects: arbitrary ExtendScript execution, background rendering, deep project/layer inspection, and native Arabic/RTL and multilingual support.",
  "main": "build/index.js",
  "type": "module",
  "author": "Abdelrahman Youssef",
  "license": "MIT",
  "homepage": "https://github.com/a-y-ibrahim/after-effects-mcp#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/a-y-ibrahim/after-effects-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/a-y-ibrahim/after-effects-mcp/issues"
  },
  "keywords": [
    "after-effects",
    "adobe",
    "mcp",
    "model-context-protocol",
    "claude",
    "ai-agent",
    "extendscript",
    "motion-graphics",
    "automation",
    "i18n",
    "rtl",
    "arabic"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc && copyfiles -u 1 \"src/scripts/**/*\" build",
    "start": "node build/index.js",
    "install-bridge": "node install-bridge.js",
    "postinstall": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "node-fetch": "^3.3.2",
    "zod": "^3.22.2"
  },
  "devDependencies": {
    "@types/node": "^20.17.30",
    "copyfiles": "^2.4.1",
    "typescript": "^5.2.2"
  }
}
